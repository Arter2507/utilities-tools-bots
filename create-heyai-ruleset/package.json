{
  "name": "@heyai-rules/heyai-ruleset",
  "version": "1.2.1",
  "description": "Scaffold and install HEYAI ruleset into a project.",
  "keywords": [
    "create",
    "cli",
    "ruleset",
    "agent"
  ],
  "homepage": "https://github.com/Arter2507/create-heyai-ruleset#readme",
  "bugs": {
    "url": "https://github.com/Arter2507/create-heyai-ruleset/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arter2507/create-heyai-ruleset.git"
  },
  "license": "Apache-2.0",
  "author": "Arter",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "create-heyai-ruleset": "index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "RELEASE.md",
    "scripts/release-check.js",
    "CODE_STANDARDS.md",
    "GIT_WORKFLOW.md",
    "IDENTITY_SOUL.md",
    "MAP.md",
    "MEMORIES.md",
    "PROTOCOLS.md",
    "RULES.md",
    "SECURITY.md",
    "SYSTEM_DESIGN.md",
    "TESTING_POLICY.md",
    "WORKFLOWS.md"
  ],
  "scripts": {
    "check": "node --check index.js",
    "pack:dry": "npm pack --dry-run",
    "release:check": "node scripts/release-check.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "semantic-release": "^24.2.3"
  },
  "release": {
    "branches": [
      "main",
      "next"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
